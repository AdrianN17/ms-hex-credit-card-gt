        }
        class BalanceSnapshot <<domain>> {
            # cardId : CardId
            # total : Amount
            # old : Amount
            # available : Amount
            # dateRange : DateRange
        }
        class BalanceConsumo <<domain>> {
            + from(balance) : BalanceConsumo
            + apply(amount) : void
            + cancel(amount) : void
            + isOvercharged() : Boolean
        }
        class BalancePago <<domain>> {
            + from(balance) : BalancePago
            + apply(amount) : void
            + cancel(amount) : void
            + isOvercharged() : Boolean
        }
        class BalanceOperable <<domain>>
        class BalanceId <<vo>>
        class BalanceException <<exception>>
        ' Factory
        interface BalanceFactory <<factory>> {
            + create(...) : Balance
        }
        class BalanceFactoryImpl <<factory>>
    }

    ' ── Agregado Benefit ────────────────────────────────────
    package "domain.benefit" {
        class Benefit <<domain>> {
            - totalPoints : Point
            - discountPolicy : DiscountPolicy
            - cardId : CardId
            + accumulate(amount, ratio) : void
            + discount(amount, usedPoints) : Amount
            + close() : void
        }
        class Point <<domain>> {
            - pointEarned : Integer
            + earnPoints(point) : Point
            + dismissPoints(point) : Point
            + multiply(multiplier) : Point
            + calculateIfHaveEnoughPoints(usedPoints) : Boolean
        }
        class BenefitException <<exception>>
        class PointException <<exception>>
        ' Value Objects
        class BenefitId <<vo>>
        class DiscountPolicy <<vo>>
    }

    ' ── Agregado Consumption ────────────────────────────────
    package "domain.consumption" {
        class Consumption <<domain>> {
            - consumptionAmount : Amount
            - consumptionApprobation : Approbation
