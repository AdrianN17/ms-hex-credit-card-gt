    ' ── Dominio Genérico ────────────────────────────────────
    package "domain.generic" {
        abstract class GenericDomain <<domain>> {
            # id : T
            # status : StatusEnum
            # createdDate : LocalDateTime
            # updatedDate : LocalDateTime
            + softDelete() : void
            + getId() : T
        }
    }

    ' ── Utilidades de Dominio ───────────────────────────────
