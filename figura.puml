' CAPA 6: DOMINIO  (Domain Model)
' ==============================================================
package "domain — Domain Model (DDD)" #FFF3E0 {

    ' ── Agregado Card ───────────────────────────────────────
    package "domain.card" {
        class Card <<domain>> {
            - typeCard : TypeCardEnum
            - categoryCard : CategoryCardEnum
            - credit : Credit
            - cardStatus : CardStatusEnum
            - cardAccountId : CardAccountId
            - paymentDay : PaymentDay
            + updateStatus(isOvercharged) : void
            + validateIfCardIfInDebt() : void
            + getRatio() : BigDecimal
            + close() : void
        }
        enum CardStatusEnum <<domain>> {
            OPERATIVE
            IN_DEBT
            OVERCHARGE
        }
        enum TypeCardEnum <<domain>> {
            VISA
            MASTERCARD
            AMEX
        }
        enum CategoryCardEnum <<domain>> {
            NORMAL
            SILVER
            GOLD
            PLATINUM
            BLACK
            SIGNATURE
            INFINITY
        }
        class CardException <<exception>>
        ' Value Objects
        class CardId <<vo>>
        class CardAccountId <<vo>>
        class Credit <<vo>>
        class PaymentDay <<vo>>
    }

    ' ── Agregado Balance ────────────────────────────────────
    package "domain.balance" {
        interface Balance <<domain>> {
            + getCardId() : CardId
            + getTotal() : Amount
            + getOld() : Amount
            + getAvailable() : Amount
            + getDateRange() : DateRange
